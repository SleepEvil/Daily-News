# Telegram 配置 (必需)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 可选配置
DAILY_NEWS_API_BASE=https://ai.6551.io
DAILY_NEWS_MAX_ROWS=10

# 获取方法:
# 1. Bot Token: 访问 https://t.me/botfather，创建新机器人，获取 token
# 2. Chat ID: 
#    - 个人: 访问 https://t.me/userinfobot，发送 /start 获取 ID
#    - 群组: 将机器人加入群组，访问 https://api.telegram.org/bot<token>/getUpdates 查找 chat.id

# 示例:
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
# TELEGRAM_CHAT_ID=123456789
